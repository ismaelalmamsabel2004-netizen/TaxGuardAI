generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaccion {
  id               Int      @id @default(autoincrement())
  userId           String
  empresaId        String?  // <-- AÑADIDO: Para saber de qué empresa es
  fecha            DateTime
  tipo             String
  baseImponible    Float
  iva              Float?
  categoria        String?
  isRecurrent      Boolean? @default(false)
  frecuencia       String?
  
  // Campos extra para Facturación PDF
  numero_factura   String?
  cliente_nombre   String?
  cliente_nif      String?
  concepto_detalle String?
  
  createdAt        DateTime @default(now())
}